@model LaLlamaDelBosque.Models.AwardConnectionModel

@{
    var availableLotteries = Model.AvailableLotteries ?? new List<LaLlamaDelBosque.Models.Lottery>();
    var hasAvailableLotteries = availableLotteries.Any();
}

<form asp-action="Add" asp-route-awardid=@Model.AwardId class="row g-3">
    <div asp-validation-summary="ModelOnly" class="text-danger"></div>
    <div class="form-group">
        <input asp-for="AwardLine.Order" class="form-control visually-hidden" />
    </div>
    <div class="form-group col-3">
        <label asp-for="AwardLine.Description" class="form-label">Descripción</label>
        <select asp-for="AwardLine.Description" class="form-select" disabled="@(!hasAvailableLotteries)">
            @if (hasAvailableLotteries)
            {
                <option value="">Seleccione un sorteo</option>
                @foreach (var lottery in availableLotteries)
                {
                    <option value="@lottery.Name">@lottery.Name</option>
                }
            }
            else
            {
                <option value="">No hay sorteos disponibles</option>
            }
        </select>
        <span asp-validation-for="AwardLine.Description" class="text-danger"></span>
        @if (!hasAvailableLotteries)
        {
            <div class="form-text text-muted">Solo se pueden agregar sorteos que ya pasaron y que aún no están en la tabla.</div>
        }
    </div>
    <div class="form-group col-1">
        <label asp-for="AwardLine.Number" class="form-label">Número</label>
        <input asp-for="AwardLine.Number" class="form-control" />
        <span asp-validation-for="AwardLine.Number" class="text-danger"></span>
    </div>
    <div class="form-group col-2">
        <label asp-for="AwardLine.Amount" class="form-label">Monto</label>
        <div class="input-group">
            <div class="input-group-text">₡</div>
            <input asp-for="AwardLine.Amount" class="form-control" />
        </div>
        <span asp-validation-for="AwardLine.Amount" class="text-danger"></span>
    </div>
    <div class="form-group col-2">
        <label asp-for="AwardLine.Busted" class="form-label">Reventado</label>
        <div class="input-group">
            <div class="input-group-text">₡</div>
            <input asp-for="AwardLine.Busted" class="form-control" />
        </div>
        <span asp-validation-for="AwardLine.Busted" class="text-danger"></span>
    </div>
    <div class="form-group col-2">
        <label asp-for="AwardLine.TimesAmount" class="form-label"># Monto</label>
        <input asp-for="AwardLine.TimesAmount" class="form-control" />
        <span asp-validation-for="AwardLine.TimesAmount" class="text-danger"></span>
    </div>
    <div class="form-group col-2">
        <label asp-for="AwardLine.TimesBusted" class="form-label"># Reventado</label>
        <input asp-for="AwardLine.TimesBusted" class="form-control" />
        <span asp-validation-for="AwardLine.TimesBusted" class="text-danger"></span>
    </div>
    <div class="form-group">
        <input type="submit" value="Crear" class="btn btn-primary" disabled="@(!hasAvailableLotteries)" />
        <input type="button" onclick="location.href='@Url.Action("Index", "Award")'" value="Cancelar" class="btn btn-secondary" />
    </div>
</form>

@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }
}
