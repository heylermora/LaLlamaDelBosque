<link href="https://fonts.googleapis.com/icon?family=Material+Icons" rel="stylesheet">

@model LotterySearchModel

<form asp-controller="Lottery" asp-action="Index" method="get">
    <div class="row g-3 align-items-end">
        <div class="col-12 col-md-3">
            <label asp-for="Id" class="form-label fw-semibold">Papelito</label>
            <input asp-for="Id" class="form-control" placeholder="Ej. 123" />
        </div>

        <div class="col-12 col-md-3">
            <label asp-for="Lottery" class="form-label fw-semibold">Sorteo</label>
            <select asp-for="Lottery" class="form-select">
                <option value="TODOS">Todos</option>
                @if (ViewData["Names"] is IList<Lottery> lotteries)
                {
                    @foreach (var item in lotteries)
                    {
                        <option value="@item.Name">@item.Name</option>
                    }
                }
            </select>
        </div>

        <div class="col-12 col-md-2">
            <label asp-for="FromDate" class="form-label fw-semibold">Desde</label>
            <input asp-for="FromDate" type="date" class="form-control" />
        </div>

        <div class="col-12 col-md-2">
            <label asp-for="ToDate" class="form-label fw-semibold">Hasta</label>
            <input asp-for="ToDate" type="date" class="form-control" />
        </div>

        <div class="col-12 col-md-2">
            <button type="submit" class="btn btn-primary d-flex align-items-center justify-content-center gap-2 fw-semibold">
                <span class="material-icons" style="font-size:20px;">search</span>
                Buscar
            </button>
        </div>
    </div>
</form>

@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }
}