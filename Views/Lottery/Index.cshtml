@model IEnumerable<Paper>

@using LaLlamaDelBosque.Utils;
@{
    ViewData["Title"] = "Listado de Ventas";
    var searchModel = ViewData["LotterySearchModel"] as LotterySearchModel;
    var numberAward = ViewBag.Number?.ToString();
    var total = 0d;
    var totales = 0d;
    var totalMonto = Model?.Sum(x => x.Numbers.Sum(n => n.Amount)) ?? 0d;
    var totalReventado = Model?.Sum(x => x.Numbers.Sum(n => n.Busted)) ?? 0d;
    var totalPapelitos = Model?.Count() ?? 0;
    var value = 0;
}

<h2 class="fw-bold mb-4">@ViewData["Title"]</h2>

<div class="card shadow-sm border-0 mb-4">
    <div class="card-body">
        <partial name="_Search" model="@searchModel" />
    </div>
</div>

@if (Model != null && Model.Any())
{
    <div class="p-2 bg-white rounded-3 shadow-sm d-inline-block mb-4">
        <ul class="nav nav-pills gap-4" id="ventasTabs" role="tablist">
            <li class="nav-item" role="presentation">
                <button class="nav-link active"
                        data-bs-toggle="tab"
                        data-bs-target="#resumen-pane"
                        type="button">
                    Resumen
                </button>
            </li>
            <li class="nav-item" role="presentation">
                <button class="nav-link"
                        data-bs-toggle="tab"
                        data-bs-target="#papelitos-pane"
                        type="button">
                    Papelitos
                </button>
            </li>
            <li class="nav-item" role="presentation">
                <button class="nav-link"
                        data-bs-toggle="tab"
                        data-bs-target="#numeros-pane"
                        type="button">
                    Números
                </button>
            </li>
        </ul>
    </div>
    <div class="tab-content" id="ventasTabsContent">
        <div class="tab-pane fade show active" id="resumen-pane" role="tabpanel" aria-labelledby="resumen-tab" tabindex="0">
            <div class="row g-3 mb-4">
                <div class="col-md-4">
                    <div class="card shadow-sm border-0 h-100 text-center">
                        <div class="card-body">
                            <div class="text-muted text-uppercase small mb-2">Número ganador</div>
                            <div class="display-4 fw-bold text-primary">@(string.IsNullOrWhiteSpace(numberAward) ? "--" : numberAward)</div>
                        </div>
                    </div>
                </div>
                <div class="col-md-8">
                    <div class="row g-3">
                        <div class="col-sm-4">
                            <div class="card shadow-sm border-0 h-100">
                                <div class="card-body text-center">
                                    <div class="text-muted small">Papelitos</div>
                                    <div class="h4 fw-bold mb-0">@totalPapelitos</div>
                                </div>
                            </div>
                        </div>
                        <div class="col-sm-4">
                            <div class="card shadow-sm border-0 h-100">
                                <div class="card-body text-center">
                                    <div class="text-muted small">Monto vendido</div>
                                    <div class="h4 fw-bold mb-0">₡ @totalMonto.ToString("N0")</div>
                                </div>
                            </div>
                        </div>
                        <div class="col-sm-4">
                            <div class="card shadow-sm border-0 h-100">
                                <div class="card-body text-center">
                                    <div class="text-muted small">Reventado</div>
                                    <div class="h4 fw-bold mb-0">₡ @totalReventado.ToString("N0")</div>
                                </div>
                            </div>
                        </div>
                    </div>

                    <div class="card shadow-sm border-0 mt-3">
                        <div class="card-body text-center">
                            <div class="text-muted small">Total general vendido</div>
                            <div class="h3 fw-bold mb-0">₡ @( (totalMonto + totalReventado).ToString("N0") )</div>
                        </div>
                    </div>
                </div>
            </div>
        </div>

        <div class="tab-pane fade" id="papelitos-pane" role="tabpanel" aria-labelledby="papelitos-tab" tabindex="0">
            <div class="card shadow-sm border-0">
                <div class="card-body">
                    <div class="d-flex flex-column flex-lg-row justify-content-between align-items-lg-center gap-3 mb-3">
                        <div>
                            <h5 class="mb-1 fw-bold">Ventas por papelito</h5>
                            <p class="text-muted mb-0">Revisa montos, reventados y estado de sorteo en un solo lugar.</p>
                        </div>
                        <div class="d-flex flex-column flex-sm-row gap-2 w-100 w-lg-auto">
                            <div class="input-group input-group-sm">
                                <span class="input-group-text bg-white"><span class="material-icons" style="font-size:18px;">search</span></span>
                                <input id="papelitoFilter" type="text" class="form-control" placeholder="Buscar por papelito o sorteo" />
                            </div>
                            <div class="form-check form-switch d-flex align-items-center m-0 px-2 border rounded">
                                <input class="form-check-input me-2" type="checkbox" id="pendingOnly">
                                <label class="form-check-label small text-nowrap" for="pendingOnly">Solo pendientes</label>
                            </div>
                        </div>
                    </div>

                    <div class="d-flex flex-wrap gap-2 mb-3">
                        <span class="badge rounded-pill text-bg-light border">Papelitos: @totalPapelitos</span>
                        <span class="badge rounded-pill text-bg-light border">Monto: ₡ @totalMonto.ToString("N0")</span>
                        <span class="badge rounded-pill text-bg-light border">Reventado: ₡ @totalReventado.ToString("N0")</span>
                    </div>

                    <div class="table-responsive">
                        <table class="table table-hover align-middle" id="papelitosTable">
                            <thead class="table-light">
                                <tr>
                                    <th>Papelito</th>
                                    <th>Sorteos</th>
                                    <th>Creación</th>
                                    <th>Sorteo</th>
                                    <th class="text-end">Monto</th>
                                    <th class="text-end">Reventado</th>
                                    <th class="text-end">Total</th>
                                    <th class="text-center">Opciones</th>
                                </tr>
                            </thead>
                            <tbody>
                                @foreach (var item in Model)
                                {
                                    var monto = item.Numbers.Sum(n => n.Amount);
                                    var reventado = item.Numbers.Sum(n => n.Busted);
                                    total = monto + reventado;
                                    totales += total;

                                    <tr data-paper-id="@item.Id" data-pending="@(item.DrawDate > DateTime.Now)">
                                        <td class="fw-semibold">#@item.Id</td>
                                        <td>
                                            <div class="d-flex flex-wrap gap-1">
                                                @foreach (var lot in (item.Lottery ?? string.Empty).Split(",", StringSplitOptions.RemoveEmptyEntries | StringSplitOptions.TrimEntries))
                                                {
                                                    <span class="badge text-bg-secondary-subtle border">@lot</span>
                                                }
                                            </div>
                                        </td>
                                        <td>
                                            <div class="small fw-semibold">@item.CreationDate.ToString("dd/MM/yyyy")</div>
                                            <div class="text-muted small">@item.CreationDate.ToString("hh:mm tt")</div>
                                        </td>
                                        <td>
                                            <div class="small fw-semibold">@item.DrawDate.ToString("dd/MM/yyyy")</div>
                                            <div class="text-muted small">@item.DrawDate.ToString("hh:mm tt")</div>
                                            @if (item.DrawDate > DateTime.Now)
                                            {
                                                <span class="badge rounded-pill text-bg-warning-subtle border mt-1">Pendiente</span>
                                            }
                                            else
                                            {
                                                <span class="badge rounded-pill text-bg-success-subtle border mt-1">Jugado</span>
                                            }
                                        </td>
                                        <td class="text-end">₡ @monto.ToString("N0")</td>
                                        <td class="text-end">₡ @reventado.ToString("N0")</td>
                                        <td class="text-end fw-bold">₡ @total.ToString("N0")</td>
                                        <td class="text-center">
                                            <div class="btn-group" role="group">
                                                <button type="button"
                                                        class="btn btn-sm btn-outline-primary"
                                                        title="Ver"
                                                        onclick="location.href='@Url.Action("Print", "Lottery", new { id = item.Id })'">
                                                    <span class="material-icons" style="font-size:20px;">visibility</span>
                                                </button>

                                                @if (item.DrawDate > DateTime.Now)
                                                {
                                                    <button type="button"
                                                            class="btn btn-sm btn-outline-danger btn-delete"
                                                            data-id="@item.Id"
                                                            title="Eliminar">
                                                        <span class="material-icons" style="font-size:20px;">delete</span>
                                                    </button>
                                                }
                                            </div>
                                        </td>
                                    </tr>

                                    <tr id="delete-partial-@item.Id" style="display:none;">
                                        <td colspan="8" class="bg-light">
                                            @{
                                                searchModel.Id = item.Id;
                                            }
                                            <partial name="_Delete" model="searchModel" />
                                        </td>
                                    </tr>
                                }
                            </tbody>
                            <tfoot class="table-light">
                                <tr>
                                    <td colspan="6" class="text-end fw-bold">TOTAL</td>
                                    <td class="text-end fw-bold">₡ @totales.ToString("N0")</td>
                                    <td></td>
                                </tr>
                            </tfoot>
                        </table>
                    </div>
                    <div id="papelitosNoResults" class="alert alert-light border text-center mt-3 d-none mb-0">
                        No hay resultados para el filtro aplicado.
                    </div>
                </div>
            </div>
        </div>

        <div class="tab-pane fade" id="numeros-pane" role="tabpanel" aria-labelledby="numeros-tab" tabindex="0">
            <div class="card shadow-sm border-0">
                <div class="card-body">
                    <div class="row g-3 justify-content-center">
                        @for (var i = 0; i < 5; i++)
                        {
                            <div class="col-12 col-md-6 col-xl">
                                <div class="table-responsive">
                                    <table class="table table-sm table-bordered align-middle text-center mb-0">
                                        <thead class="table-light">
                                            <tr>
                                                <th>#</th>
                                                <th>Monto</th>
                                                <th>Rtado</th>
                                            </tr>
                                        </thead>
                                        <tbody>
                                            @for (var j = 0; j < 20; j++)
                                            {
                                                value = 20 * i + j;
                                                var currentNumber = value.ToString("D2");
                                                var isWinner = currentNumber == numberAward;
                                                var rowClass = isWinner ? "table-warning fw-bold" : "";
                                                var sumAmount = Model.Sum(m => m.Numbers.Where(n => n.Value == currentNumber).Sum(n => n.Amount));
                                                var sumBusted = Model.Sum(m => m.Numbers.Where(n => n.Value == currentNumber).Sum(n => n.Busted));

                                                <tr class="@rowClass">
                                                    <td>@currentNumber</td>
                                                    <td>@(sumAmount > 0 ? $"₡ {sumAmount:N0}" : "-")</td>
                                                    <td>@(sumBusted > 0 ? $"₡ {sumBusted:N0}" : "-")</td>
                                                </tr>
                                            }
                                        </tbody>
                                    </table>
                                </div>
                            </div>
                        }
                    </div>
                </div>
            </div>
        </div>
    </div>
}
else
{
    <div class="alert alert-light border text-center shadow-sm">
        No hay ventas para mostrar.
    </div>
}

@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }
    <script type="text/javascript">
        $(function() {
            $(".btn-delete").click(function() {
                var id = $(this).data("id");
                $("#delete-partial-" + id).toggle();
            });

            function filterPapelitos() {
                var query = ($("#papelitoFilter").val() || "").toLowerCase().trim();
                var onlyPending = $("#pendingOnly").is(":checked");
                var visibleRows = 0;

                $("#papelitosTable tbody tr").not("[id^='delete-partial-']").each(function() {
                    var row = $(this);
                    var rowText = row.text().toLowerCase();
                    var isPending = (row.data("pending") === true || row.data("pending") === "True");
                    var matchQuery = !query || rowText.indexOf(query) >= 0;
                    var matchPending = !onlyPending || isPending;
                    var show = matchQuery && matchPending;

                    row.toggle(show);
                    var deleteRow = $("#delete-partial-" + row.data("paper-id"));
                    if (!show) {
                        deleteRow.hide();
                    }

                    if (show) {
                        visibleRows++;
                    }
                });

                $("#papelitosNoResults").toggleClass("d-none", visibleRows > 0);
            }

            $("#papelitoFilter").on("input", filterPapelitos);
            $("#pendingOnly").on("change", filterPapelitos);
        });
    </script>
}

<style>
    #papelitos-pane .table thead th {
        white-space: nowrap;
    }

    #papelitos-pane .badge.text-bg-secondary-subtle,
    #papelitos-pane .badge.text-bg-warning-subtle,
    #papelitos-pane .badge.text-bg-success-subtle {
        color: #212529;
    }
</style>
