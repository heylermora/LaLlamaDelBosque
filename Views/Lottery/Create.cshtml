@model Paper
@using LaLlamaDelBosque.Utils;

@{
    ViewData["Title"] = "Crear Papelito";
    var selectedLotteryCount = Model?.SelectedLotteries?.Count ?? 0;
    if (selectedLotteryCount == 0 && !string.IsNullOrWhiteSpace(Model?.Lottery))
    {
        selectedLotteryCount = Model.Lottery
            .Split(',', StringSplitOptions.RemoveEmptyEntries)
            .Select(x => x.Trim())
            .Count(x => !string.IsNullOrWhiteSpace(x));
    }

    var subsum = Model?.Numbers.Sum(x => x.Amount) + Model?.Numbers.Sum(x => x.Busted) ?? 0;
    var sum = subsum * selectedLotteryCount;
    var hasSelectedLotteries = selectedLotteryCount > 0;
}

<div class="container py-2">
    <div class="row align-items-center g-3 mb-4">
        <div class="col-12 col-lg">
            <div class="d-flex align-items-center gap-3">
                <div class="rounded-4 bg-primary bg-opacity-10 d-flex align-items-center justify-content-center shadow-sm"
                     style="width:56px;height:56px;">
                    <span class="material-icons text-primary">receipt_long</span>
                </div>

                <div>
                    <h1 class="h3 fw-bold mb-1">@ViewData["Title"]</h1>
                    <p class="text-muted mb-0">Configura sorteo, cliente y números para crear el papelito.</p>
                </div>
            </div>
        </div>

        <div class="col-12 col-lg-auto">
            <form asp-action="Copy" method="post">
                <label class="form-label fw-semibold small text-muted mb-2">
                    Copiar papelito
                </label>

                <div class="input-group">
                    <span class="input-group-text bg-white border-end-0">
                        <span class="material-icons text-muted">content_copy</span>
                    </span>

                    <input type="text"
                           class="form-control border-start-0"
                           placeholder="Digite el número"
                           name="id">

                    <button type="submit" class="btn btn-primary px-4">
                        Copiar
                    </button>
                </div>
            </form>
        </div>
    </div>

    <div id="lotteryAlertHost" class="mb-3" aria-live="polite">
        @if (TempData["ErrorMessage"] is string errorMessage && !string.IsNullOrWhiteSpace(errorMessage))
        {
            <div class="alert alert-danger alert-dismissible fade show" role="alert">
                <div class="d-flex gap-2 align-items-start">
                    <span class="material-icons">error</span>
                    <span>@errorMessage</span>
                </div>
                <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Cerrar"></button>
            </div>
        }
    </div>

    <form asp-action="Save" method="post" id="savePaperForm">

        <div class="card mb-3">
            <div class="card-body">
                <div class="row g-3 align-items-end">
                    <div class="col-md-2">
                        <label asp-for="Id" class="form-label">Papelito</label>
                        <input asp-for="Id" class="form-control" disabled readonly />
                    </div>

                    <div class="col-md-3">
                        <label asp-for="DrawDate" class="form-label">Fecha</label>
                        <input asp-for="DrawDate"
                               type="date"
                               min="@DateTime.Now.ToString("yyyy-MM-dd")"
                               class="form-control"
                               onchange="loadLotteriesByDate()" />
                    </div>

                    <div class="col-md-4">
                        <label asp-for="SelectedLotteries" class="form-label">Sorteos</label>

                        <div class="position-relative">
                            <div id="customSelect" class="form-select" onclick="toggleDropdown()">
                                <span id="selectedLotteriesText" class="text-truncate d-block">
                                    Seleccione uno o varios
                                </span>
                            </div>

                            <ul id="customDropdown" class="dropdown-menu w-100 p-0">
                                @if (ViewData["Names"] is IList<Lottery> lotteries)
                                {
                                    <li class="px-3 py-2 bg-light">
                                        <input type="checkbox"
                                               class="form-check-input me-2"
                                               id="selectAll"
                                               onchange="toggleSelectAll(this)"
                                        @(Model?.SelectedLotteries.Count() == lotteries.Count() ? "checked" : "") />

                                        <label class="form-check-label fw-bold" for="selectAll">
                                            Seleccionar todos
                                        </label>
                                    </li>

                                    foreach (var item in lotteries)
                                    {
                                        <li class="px-3 py-2">
                                            <input type="checkbox"
                                                   class="form-check-input child-checkbox me-2"
                                                   name="SelectedLotteries"
                                                   value="@item.Name"
                                                   id="lottery_@item.Order"
                                                   data-busted="@((item.Busted ?? false).ToString().ToLower())"
                                                   onchange="updateSelected()"
                                            @(Model?.SelectedLotteries.Contains(item.Name) ?? false ? "checked" : "") />

                                            <label class="form-check-label" for="lottery_@item.Order">
                                                @item.Name
                                            </label>
                                        </li>
                                    }
                                }
                            </ul>
                        </div>
                    </div>

                    <div class="col-md-3">
                        <label asp-for="ClientId" class="form-label">Cliente</label>
                        <select asp-for="ClientId" class="form-select">
                            <option value="-1">Seleccione un nombre</option>
                            @foreach (var item in ViewData["Clients"] as IList<Client> ?? new List<Client>())
                            {
                                <option value="@item.Id">@item.Name</option>
                            }
                        </select>
                    </div>
                </div>
            </div>
        </div>

        <input type="hidden" id="selectedLotteriesHidden" name="selectedLotteries" value="@string.Join(",", Model.SelectedLotteries)" />
        <input type="hidden" id="numbersDraftJson" name="numbersDraftJson" value="" />
    </form>

    <div class="row g-3">
        <div class="col-lg-8">
            <div id="addSection" class="@(hasSelectedLotteries ? "" : "d-none") mb-3">
                <div class="card">
                    <div class="card-body">
                        <div class="mb-3">
                            <h5 class="mb-2">Agregar números</h5>

                            <div class="d-flex flex-wrap gap-1" id="selectedLotteriesBadges">
                                @foreach (var name in Model?.SelectedLotteries ?? new List<string>())
                                {
                                    <span class="badge bg-primary">@name</span>
                                }
                            </div>
                        </div>

                        <partial name="_AddNumbers" model="new Numbers()" />
                    </div>
                </div>
            </div>
            <div id="numbersSection" class="@((Model?.Numbers.Any() ?? false) ? "" : "d-none")">
                <div class="card">
                    <div class="card-body">
                        <partial name="_StagedNumbers" model="Model" />
                    </div>
                </div>
            </div>
        </div>

        <div class="col-lg-4">
            <div class="card ds-gradient-card h-100">
                <div class="card-body">
                    <div class="d-flex justify-content-between align-items-start mb-4">
                        <div>
                            <h5 class="mb-1">Confirmación</h5>
                            <small class="opacity-75">Detalle del papelito</small>
                        </div>
                        <span class="material-icons">receipt_long</span>
                    </div>

                    <div class="d-flex justify-content-between mb-2">
                        <span class="opacity-75">Papelitos</span>
                        <strong id="summaryPaperCount">@selectedLotteryCount</strong>
                    </div>

                    <div class="d-flex justify-content-between mb-2">
                        <span class="opacity-75">Monto</span>
                        <strong id="summaryAmountTotal">@Model?.Numbers.Sum(x => x.Amount).ToCRC()</strong>
                    </div>

                    <div class="d-flex justify-content-between mb-3">
                        <span class="opacity-75">Reventado</span>
                        <strong id="summaryBustedTotal">@Model?.Numbers.Sum(x => x.Busted).ToCRC()</strong>
                    </div>

                    <hr class="opacity-50" />

                    <div class="d-flex justify-content-between mb-2">
                        <span class="opacity-75">Total papelito</span>
                        <strong id="summaryPaperTotal">@subsum.ToCRC()</strong>
                    </div>

                    <div class="d-flex justify-content-between align-items-end">
                        <span class="opacity-75">Total general</span>
                        <strong class="fs-2" id="summaryGrandTotal">@sum.ToCRC()</strong>
                    </div>

                    <div class="d-grid gap-2 mt-4">
                        <button type="submit"
                                form="savePaperForm"
                                id="createPaperButton"
                                class="btn btn-light fw-semibold">
                            Crear papelito
                        </button>

                        <button type="button"
                                onclick="clearLotteryForm()"
                                class="btn btn-outline-light">
                            Limpiar todo
                        </button>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }

    <script type="text/javascript">
        const LOTTERY_DRAFT_KEY = "lottery_add_form_draft_v1";
        let stagedNumbers = @Html.Raw(Json.Serialize(Model?.Numbers ?? new List<Number>()));

        function showLotteryAlert(message, type = "warning") {
            const host = document.getElementById("lotteryAlertHost");
            if (!host) return;

            const icon = type === "danger" ? "error" : type === "success" ? "check_circle" : "info";

            host.innerHTML = `
                <div class="alert alert-${type} alert-dismissible fade show" role="alert">
                    <div class="d-flex gap-2 align-items-start">
                        <span class="material-icons">${icon}</span>
                        <span>${message}</span>
                    </div>
                    <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Cerrar"></button>
                </div>
            `;
            host.scrollIntoView({ behavior: "smooth", block: "nearest" });
        }

        function clearLotteryAlert() {
            const host = document.getElementById("lotteryAlertHost");
            if (host) host.innerHTML = "";
        }

        function toggleElement(id, show) {
            const element = document.getElementById(id);
            if (!element) return;

            element.classList.toggle("d-none", !show);
        }

        function padNumber(value) {
            return value.toString().padStart(2, "0");
        }

        function explodeDigitChunk(chunk) {
            if (!chunk) return [];

            if (chunk.length <= 2) {
                const value = parseInt(chunk, 10);
                return Number.isNaN(value) || value < 0 || value > 99 ? [] : [padNumber(value)];
            }

            const normalized = chunk.length % 2 === 0 ? chunk : `0${chunk}`;
            const values = [];

            for (let i = 0; i < normalized.length; i += 2) {
                const value = parseInt(normalized.slice(i, i + 2), 10);

                if (!Number.isNaN(value) && value >= 0 && value <= 99) {
                    values.push(padNumber(value));
                }
            }

            return values;
        }

        function parseNumbersFromText(raw) {
            if (!raw) return [];

            return raw
                .split("+")
                .map(x => x.trim())
                .filter(Boolean)
                .flatMap(explodeDigitChunk);
        }

        function saveDraftState() {
            const draft = {
                amount: document.getElementById("Amount")?.value || "",
                busted: document.getElementById("Busted")?.value || "",
                bulk: document.getElementById("bulkNumbersInput")?.value || "",
                stagedNumbers
            };

            sessionStorage.setItem(LOTTERY_DRAFT_KEY, JSON.stringify(draft));
        }

        function restoreDraftState() {
            const raw = sessionStorage.getItem(LOTTERY_DRAFT_KEY);
            if (!raw) return;

            try {
                const draft = JSON.parse(raw);

                if (document.getElementById("Amount") && draft.amount) {
                    document.getElementById("Amount").value = draft.amount;
                }

                if (document.getElementById("Busted") && draft.busted) {
                    document.getElementById("Busted").value = draft.busted;
                }

                if (document.getElementById("bulkNumbersInput") && draft.bulk) {
                    document.getElementById("bulkNumbersInput").value = draft.bulk;
                }

                if (Array.isArray(draft.stagedNumbers)) {
                    stagedNumbers = draft.stagedNumbers;
                }
            } catch {
                sessionStorage.removeItem(LOTTERY_DRAFT_KEY);
            }
        }

        function addNumbersFromTextarea() {
            document.getElementById("addNumberForm")?.requestSubmit();
        }

        function formatCrc(value) {
            return Number(value || 0).toLocaleString("es-CR", {
                style: "currency",
                currency: "CRC"
            });
        }

        function renderSelectedLotteriesBadges(values) {
            const container = document.getElementById("selectedLotteriesBadges");
            if (!container) return;

            container.innerHTML = "";

            values.forEach(value => {
                const badge = document.createElement("span");
                badge.className = "badge bg-primary";
                badge.textContent = value;
                container.appendChild(badge);
            });
        }

        function renderStagedNumbersTable() {
            const body = document.getElementById("numbersTableBody");
            if (!body) return;

            const selectedCount = (document.getElementById("selectedLotteriesHidden")?.value || "")
                .split(",")
                .filter(Boolean).length;

            body.innerHTML = "";

            stagedNumbers.forEach((item, index) => {
                const value = item.value ?? item.Value ?? "";
                const amount = Number(item.amount ?? item.Amount ?? 0);
                const busted = Number(item.busted ?? item.Busted ?? 0);

                body.insertAdjacentHTML("beforeend", `
                    <tr>
                        <td></td>
                        <td class="fw-bold">${value}</td>
                        <td>${formatCrc(amount)}</td>
                        <td>${formatCrc(busted)}</td>
                        <td class="text-end">
                            <button type="button"
                                    class="btn btn-link text-danger remove-line-btn"
                                    data-index="${index}">
                                <span class="material-icons icon icon-danger">delete</span>
                            </button>
                        </td>
                    </tr>
                `);
            });

            body.querySelectorAll(".remove-line-btn").forEach(btn => {
                btn.addEventListener("click", () => {
                    stagedNumbers.splice(btn.dataset.index, 1);
                    renderStagedNumbersTable();
                    saveDraftState();
                });
            });

            const amountTotal = stagedNumbers.reduce((a, n) => a + Number(n.amount ?? n.Amount ?? 0), 0);
            const bustedTotal = stagedNumbers.reduce((a, n) => a + Number(n.busted ?? n.Busted ?? 0), 0);
            const paperTotal = amountTotal + bustedTotal;

            document.getElementById("summaryPaperCount").textContent = selectedCount;
            document.getElementById("summaryAmountTotal").textContent = formatCrc(amountTotal);
            document.getElementById("summaryBustedTotal").textContent = formatCrc(bustedTotal);
            document.getElementById("summaryPaperTotal").textContent = formatCrc(paperTotal);
            document.getElementById("summaryGrandTotal").textContent = formatCrc(paperTotal * selectedCount);

            const totalLinesBadge = document.getElementById("totalLinesBadge");
            if (totalLinesBadge) {
                totalLinesBadge.textContent = `Total líneas: ${stagedNumbers.length}`;
            }

            document.getElementById("createPaperButton").disabled =
                selectedCount === 0 || stagedNumbers.length === 0;

            toggleElement("numbersSection", stagedNumbers.length > 0);
        }
        function toggleDropdown() {
            document.getElementById("customDropdown")?.classList.toggle("show");
        }

        function updateSelected() {
            const dropdown = document.getElementById("customDropdown");
            if (!dropdown) return;

            const checked = [...dropdown.querySelectorAll('input[name="SelectedLotteries"]:checked')];
            const values = checked.map(cb => cb.value);
            const hasBustedLottery = checked.some(cb => cb.dataset.busted === "true");

            document.getElementById("selectedLotteriesText").textContent =
                values.length ? values.join(", ") : "Seleccione uno o varios";

            document.getElementById("selectedLotteriesHidden").value = values.join(",");

            const addSelectedLotteries = document.getElementById("addSelectedLotteries");
            if (addSelectedLotteries) addSelectedLotteries.value = values.join(",");

            renderSelectedLotteriesBadges(values);

            toggleElement("addSection", values.length > 0);

            document.getElementById("bustedGroup")?.classList.toggle("d-none", !hasBustedLottery);

            const hasVisibleAlert = Boolean(document.querySelector("#lotteryAlertHost .alert"));
            if (!values.length && !hasVisibleAlert) {
                showLotteryAlert("Seleccione al menos un sorteo para habilitar la carga de números.", "info");
            } else if (values.length) {
                clearLotteryAlert();
            }

            if (!hasBustedLottery) {
                const bustedInput = document.getElementById("Busted");
                if (bustedInput) bustedInput.value = "0";
            }

            renderStagedNumbersTable();
            saveDraftState();
        }
        function toggleSelectAll(masterCheckbox) {
            const dropdown = document.getElementById("customDropdown");
            if (!dropdown) return;

            dropdown
                .querySelectorAll('input[name="SelectedLotteries"]')
                .forEach(cb => cb.checked = masterCheckbox.checked);

            updateSelected();
        }

        async function loadLotteriesByDate() {
            const drawDateInput = document.getElementById("DrawDate");
            const drawDate = drawDateInput?.value;
            const dropdown = document.getElementById("customDropdown");

            if (!drawDate || !dropdown) return;

            const hasData =
                stagedNumbers.length > 0 ||
                ($("#bulkNumbersInput").val() || "").trim() !== "";

            if (hasData) {
                const confirmed = confirm(
                    "Cambiar la fecha actualizará los sorteos disponibles y podría eliminar sorteos incompatibles. ¿Desea continuar?"
                );

                if (!confirmed) {
                    drawDateInput.value = previousDrawDate;
                    return;
                }
            }

            const previousSelected = (
                document.getElementById("selectedLotteriesHidden")?.value || ""
            )
                .split(",")
                .map(x => x.trim())
                .filter(Boolean);

            const response = await fetch(`/Lottery/GetAvailableLotteries?drawDate=${encodeURIComponent(drawDate)}`);

            if (!response.ok) {
                showLotteryAlert("No se pudieron cargar los sorteos. Intente nuevamente.", "danger");
                drawDateInput.value = previousDrawDate;
                return;
            }

            const lotteries = await response.json();

            dropdown.innerHTML = `
                <li class="px-3 py-2 bg-light">
                    <input type="checkbox"
                           class="form-check-input me-2"
                           id="selectAll"
                           onchange="toggleSelectAll(this)" />

                    <label class="form-check-label fw-bold" for="selectAll">
                        Seleccionar todos
                    </label>
                </li>
            `;

            if (!lotteries.length) {
                showLotteryAlert("No hay sorteos disponibles para la fecha seleccionada.", "warning");
            }

            lotteries.forEach(item => {
                const isChecked = previousSelected.includes(item.name);

                dropdown.insertAdjacentHTML("beforeend", `
                    <li class="px-3 py-2">
                        <input type="checkbox"
                               class="form-check-input child-checkbox me-2"
                               name="SelectedLotteries"
                               value="${item.name}"
                               id="lottery_${item.order}"
                               data-busted="${item.busted}"
                               onchange="updateSelected()"
                               ${isChecked ? "checked" : ""} />

                        <label class="form-check-label" for="lottery_${item.order}">
                            ${item.name}
                        </label>
                    </li>
                `);
            });

            previousDrawDate = drawDate;
            updateSelected();
        }

        function clearLotteryForm() {
            sessionStorage.removeItem(LOTTERY_DRAFT_KEY);
            location.href = '@Url.Action("Clear", "Lottery")';
        }

        let previousDrawDate = "";

        $(document).ready(function () {
            previousDrawDate = $("#DrawDate").val();
            const shouldClearDraft = @((TempData["ClearLotteryDraft"] is bool clear && clear).ToString().ToLower());

            if (shouldClearDraft) {
                sessionStorage.removeItem(LOTTERY_DRAFT_KEY);
            }

            restoreDraftState();
            renderStagedNumbersTable();

            const bulkInput = document.getElementById("bulkNumbersInput");

            if (bulkInput) {
                bulkInput.addEventListener("input", function () {
                    const digitsOnly = bulkInput.value.replace(/\D/g, "");
                    const groups = [];

                    for (let i = 0; i < digitsOnly.length; i += 2) {
                        groups.push(digitsOnly.slice(i, i + 2));
                    }

                    bulkInput.value = groups.join("+");
                });
            }

            $("#addNumberForm").submit(function (e) {
                e.preventDefault();

                const amount = parseFloat($("#Amount").val());
                const busted = parseFloat($("#Busted").val() || "0");
                const numbers = parseNumbersFromText($("#bulkNumbersInput").val());
                const feedback = document.getElementById("numberFeedback");

                if (!numbers.length) {
                    if (feedback) feedback.textContent = "Digite al menos un número válido.";
                    showLotteryAlert("Digite al menos un número válido antes de agregar.", "warning");
                    return;
                }

                if (Number.isNaN(amount) || amount <= 0) {
                    $('[data-valmsg-for="Amount"]').text("El monto es obligatorio y debe ser mayor a 0.");
                    showLotteryAlert("El monto es obligatorio y debe ser mayor a 0.", "warning");
                    $("#Amount").focus();
                    return;
                }

                if (Number.isNaN(busted) || busted < 0 || busted > amount) {
                    $('[data-valmsg-for="Busted"]').text("El reventado no puede ser negativo ni mayor que el monto.");
                    showLotteryAlert("El reventado no puede ser negativo ni mayor que el monto.", "warning");
                    $("#Busted").focus();
                    return;
                }

                $('[data-valmsg-for="Amount"]').text("");
                $('[data-valmsg-for="Busted"]').text("");

                numbers.forEach(value => {
                    const existing = stagedNumbers.find(n => (n.value ?? n.Value) === value);

                    if (existing) {
                        existing.amount = Number(existing.amount ?? existing.Amount ?? 0) + amount;
                        existing.busted = Number(existing.busted ?? existing.Busted ?? 0) + busted;
                    } else {
                        stagedNumbers.push({ value, amount, busted });
                    }
                });

                stagedNumbers.sort((a, b) => (a.value ?? a.Value).localeCompare(b.value ?? b.Value));

                $("#bulkNumbersInput").val("");
                $("#Amount").val("");
                $("#Busted").val("");
                $("#Amount").focus();

                if (feedback) feedback.textContent = "";
                showLotteryAlert(`${numbers.length} número(s) agregados correctamente.`, "success");

                renderStagedNumbersTable();
                saveDraftState();
            });

            $("#savePaperForm").submit(function (event) {
                const selectedLotteryValues = ($("#selectedLotteriesHidden").val() || "")
                    .split(",")
                    .map(x => x.trim())
                    .filter(Boolean);

                if (!selectedLotteryValues.length) {
                    event.preventDefault();
                    showLotteryAlert("Debe seleccionar al menos un sorteo.", "warning");
                    return;
                }

                if (!$("#DrawDate").val()) {
                    event.preventDefault();
                    $("#DrawDate").focus();
                    showLotteryAlert("La fecha de sorteo es obligatoria.", "warning");
                    return;
                }

                if (!stagedNumbers.length) {
                    event.preventDefault();
                    showLotteryAlert("Debe agregar al menos una línea de números.", "warning");
                    return;
                }

                $("#numbersDraftJson").val(JSON.stringify(stagedNumbers));
            });

            document.addEventListener("click", function (event) {
                const dropdown = document.getElementById("customDropdown");
                const customSelect = document.getElementById("customSelect");

                if (!dropdown || !customSelect) return;

                if (!customSelect.contains(event.target) && !dropdown.contains(event.target)) {
                    dropdown.classList.remove("show");
                }
            });

            updateSelected();
        });
    </script>
}