@{
    Layout = "";
    ViewData["Title"] = "Acceder";
}

<!DOCTYPE html>
<html lang="en">
    <head>
        <meta charset="utf-8" />
        <meta name="viewport" content="width=device-width, initial-scale=1.0" />
        <title>@ViewData["Title"] - La Llama Del Bosque</title>
        <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
        <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
        <link rel="stylesheet" href="~/LaLlamaDelBosque.styles.css" asp-append-version="true" />

        <meta charset="utf-8">
        <meta name="viewport" content="width=device-width, initial-scale=1.0">
        <title>Untitled</title>
        <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/twitter-bootstrap/4.1.3/css/bootstrap.min.css">
        <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/ionicons/2.0.1/css/ionicons.min.css">
    </head>
    <body>
        <div class="login-dark">
            <form method="post">
                <div class="illustration"><i class="icon ion-ios-locked-outline"></i></div>
                <div class="form-group"><input class="form-control" type="email" name="email" placeholder="Email"></div>
                <div class="form-group"><input class="form-control" type="password" name="password" placeholder="Contraseña"></div>
            <div class="form-group"><button class="btn btn-primary btn-block" type="submit">Acceder</button></div>
            @if(ViewData["MENSAJE"] != null){
                <div class="alert alert-success" role="alert">@ViewData["MENSAJE"]</div>
            }
            </form>
        </div>
    </body>
</html>

<style>
    .login-dark {
        min-height: 100vh;
        padding: 24px;
        background: linear-gradient(rgba(16, 32, 46, 0.45), rgba(10, 18, 28, 0.72)), url("https://images.unsplash.com/photo-1473186578172-c141e6798cf4?q=80&w=1973&auto=format&fit=crop&ixlib=rb-4.1.0&ixid=M3wxMjA3fDB8MHxwaG90by1wYWdlfHx8fGVufDB8fHx8fA%3D%3D");
        background-position: center;
        background-size: cover;
        background-repeat: no-repeat;
        background-attachment: fixed;
        display: flex;
        align-items: center;
        justify-content: center;
    }

        .login-dark form {
            width: 100%;
            max-width: 420px;
            padding: 36px 32px;
            border-radius: 18px;
            background: rgba(21, 38, 52, 0.72);
            border: 1px solid rgba(255, 255, 255, 0.10);
            box-shadow: 0 20px 45px rgba(0, 0, 0, 0.35);
            backdrop-filter: blur(10px);
            -webkit-backdrop-filter: blur(10px);
        }

        .login-dark .illustration {
            text-align: center;
            font-size: 64px;
            line-height: 1;
            margin-bottom: 24px;
            color: #8fbfd1;
        }

        .login-dark .form-group {
            margin-bottom: 16px;
        }

        .login-dark .form-control {
            height: 48px;
            border-radius: 12px;
            border: 1px solid rgba(143, 191, 209, 0.35);
            background: rgba(255, 255, 255, 0.08);
            color: #f4f7fa;
            box-shadow: none;
            transition: all 0.2s ease;
        }

            .login-dark .form-control::placeholder {
                color: rgba(244, 247, 250, 0.65);
            }

            .login-dark .form-control:focus {
                border-color: #8fbfd1;
                background: rgba(255, 255, 255, 0.12);
                box-shadow: 0 0 0 0.2rem rgba(143, 191, 209, 0.18);
                color: #fff;
            }

        .login-dark form .btn-primary {
            height: 48px;
            border: none;
            border-radius: 12px;
            margin-top: 8px;
            background: linear-gradient(135deg, #3e6f82, #5fa6b8);
            color: #fff;
            font-weight: 600;
            letter-spacing: 0.3px;
            box-shadow: 0 10px 20px rgba(62, 111, 130, 0.28);
            transition: all 0.2s ease;
        }

            .login-dark form .btn-primary:hover,
            .login-dark form .btn-primary:focus {
                background: linear-gradient(135deg, #355f70, #4f95a6);
                transform: translateY(-1px);
                box-shadow: 0 14px 24px rgba(62, 111, 130, 0.34);
            }

            .login-dark form .btn-primary:active {
                transform: translateY(0);
                box-shadow: 0 8px 16px rgba(62, 111, 130, 0.25);
            }

        .login-dark .alert {
            margin-top: 16px;
            border-radius: 12px;
            border: none;
        }

    @@media (max-width: 576px) {
        .login-dark {
            padding: 16px;
            background-attachment: scroll;
        }

            .login-dark form {
                padding: 28px 20px;
                border-radius: 16px;
            }

            .login-dark .illustration {
                font-size: 52px;
                margin-bottom: 20px;
            }
    }
</style>