@model LaLlamaDelBosque.Models.SummaryModel

@{
    ViewData["TitleC"] = "Resumen de Créditos";
    ViewData["TitleL"] = "Resumen de Sorteos";
}

<h2 class="fw-bold mb-4">@ViewData["TitleC"]</h2>

<div class="container">
    <div class="row g-3">

        <!-- Cards resumen -->
        <div class="col-md-4">
            <div class="card shadow-sm text-center h-100">
                <div class="card-body">
                    <small class="text-muted">Clientes</small>
                    <h2 class="fw-bold">@Model.Credit.Clients</h2>
                    <p class="text-muted small mb-0">@Model.Credit.ClientsDescription</p>
                </div>
            </div>
        </div>

        <div class="col-md-4">
            <div class="card shadow-sm text-center h-100">
                <div class="card-body">
                    <small class="text-muted">Por cobrar</small>
                    <h2 class="fw-bold">₡ @Model.Credit.Receivable</h2>
                    <p class="text-muted small mb-0">Pendientes</p>
                </div>
            </div>
        </div>

        <div class="col-md-4">
            <div class="card shadow-sm text-center h-100">
                <div class="card-body">
                    <small class="text-muted">Abonos hoy</small>
                    <h2 class="fw-bold">₡ @Model.Credit.Received</h2>
                    <p class="text-muted small mb-0">Pagados</p>
                </div>
            </div>
        </div>

        <!-- Listas -->
        <div class="col-md-4">
            <div class="card shadow-sm h-100">
                <div class="card-body">
                    <h6 class="fw-semibold mb-3">Mayor deuda</h6>
                    <ul class="list-group list-group-flush">
                        @foreach (var item in Model.Credit.MajorDebts)
                        {
                            <li class="list-group-item d-flex justify-content-between">
                                <span>@item.Name</span>
                                <strong>₡ @item.Amount</strong>
                            </li>
                        }
                    </ul>
                </div>
            </div>
        </div>

        <div class="col-md-4">
            <div class="card shadow-sm h-100">
                <div class="card-body">
                    <h6 class="fw-semibold mb-3">Menor deuda</h6>
                    <ul class="list-group list-group-flush">
                        @foreach (var item in Model.Credit.MinorDebts)
                        {
                            <li class="list-group-item d-flex justify-content-between">
                                <span>@item.Name</span>
                                <strong>₡ @item.Amount</strong>
                            </li>
                        }
                    </ul>
                </div>
            </div>
        </div>

        <div class="col-md-4">
            <div class="card shadow-sm h-100">
                <div class="card-body">
                    <h6 class="fw-semibold mb-3">Inactivos</h6>
                    <ul class="list-group list-group-flush">
                        @foreach (var item in Model.Credit.InactiveClients)
                        {
                            <li class="list-group-item d-flex justify-content-between">
                                <span>@item.Name</span>
                                <strong>₡ @item.Amount</strong>
                            </li>
                        }
                    </ul>
                </div>
            </div>
        </div>

    </div>
</div>

<hr class="my-5" />

<h2 class="fw-bold mb-4">@ViewData["TitleC"]</h2>

<div class="container mb-2">
    <div class="row g-3">

        <div class="col-md-3">
            <div class="card shadow-sm text-center h-100">
                <div class="card-body">
                    <small class="text-muted">Papelitos</small>
                    <h3 class="fw-bold">@Model.Lottery.Papers</h3>
                    <p class="text-muted small mb-0">Facturados</p>
                </div>
            </div>
        </div>

        <div class="col-md-3">
            <div class="card shadow-sm text-center h-100">
                <div class="card-body">
                    <small class="text-muted">Monto total</small>
                    <h3 class="fw-bold">₡ @Model.Lottery.TotalAmount</h3>
                    <p class="text-muted small mb-0">Pagados</p>
                </div>
            </div>
        </div>

        <div class="col-md-3">
            <div class="card shadow-sm text-center h-100">
                <div class="card-body">
                    <small class="text-muted">Reventado</small>
                    <h3 class="fw-bold">₡ @Model.Lottery.TotalBusted</h3>
                    <p class="text-muted small mb-0">Pagados</p>
                </div>
            </div>
        </div>

        <div class="col-md-3">
            <div class="card shadow-sm text-center h-100">
                <div class="card-body">
                    <small class="text-muted">Venta total</small>
                    <h3 class="fw-bold">₡ @Model.Lottery.Total</h3>
                    <p class="text-muted small mb-0">Pagados</p>
                </div>
            </div>
        </div>

    </div>
</div>